# ========== 云端 LLM API（用于最终回复生成）==========
# 阿里云百炼（qwen-flash，OpenAI 兼容接口）
DASHSCOPE_API_KEY=your_dashscope_api_key_here
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen-flash

# ========== n8n 工单通知 webhook（可选）==========
# 留空则跳过 webhook，仅本地落库 tickets.json，不影响主流程
# Docker 部署时按 README 说明调整为 host.docker.internal 或 n8n 服务名
N8N_WEBHOOK_URL=http://localhost:5678/webhook/ticket-created

# ========== SMTP（仅供 n8n 工作流引用，本项目代码不读）==========
# 这几个变量本项目 Python 代码不会读取
# 它们由 n8n 工作流的 Send Email 节点使用（在 n8n WebUI 里配 SMTP credential）
# 列在此处只是文档化，方便一站式查阅
SMTP_HOST=smtp.163.com
SMTP_PORT=465
SMTP_USER=your_sender@163.com
SMTP_PASSWORD=your_163_smtp_authcode  # 163 邮箱授权码，不是登录密码
